# Application Configuration
APP_NAME="KLE Blog Frontend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Backend API Configuration
# Point this to the backend API URL (local or docker service name)
KLE_API_URL=http://localhost:8000/api

# Session and Cache
SESSION_DRIVER=file
CACHE_DRIVER=file
