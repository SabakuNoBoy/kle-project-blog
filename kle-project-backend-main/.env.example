# Application Configuration
APP_NAME="KLE Blog"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database Configuration
# These are default settings for the Docker environment
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=kledb
DB_USERNAME=kleuser
DB_PASSWORD=password

# Cache, Session, and Queue
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Sanctum / CORS
# Add the frontend URL here for authentication to work correctly
SANCTUM_STATEFUL_DOMAINS=localhost:8001
CORS_ALLOWED_ORIGINS=http://localhost:8001

# Filesystem
FILESYSTEM_DISK=public

# API Configuration
# This is currently used by the frontend to locate the backend
KLE_API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:8001
